# lampgo 环境变量配置
# 复制为 .env 并填入你的实际值
# .env 文件不会被提交到 git (已在 .gitignore 中)

# === 硬件端口 ===
# 如果你的串口固定，可以在这里设置，就不用每次命令行传参
LAMPGO_MOTOR_PORT=/dev/ttyUSB0
LAMPGO_LED_PORT=
LAMPGO_LAMP_ID=AL02

# === LLM API 密钥 ===
# 推荐：密钥由 `lampgo onboard` 或 Web UI 写入 ~/.lampgo/credentials.json（0600 权限）
# 这里是高级/临时覆盖层 —— 设置后会覆盖 ~/.lampgo/ 里存的值
LAMPGO_LLM_API_KEY=your-api-key-here
LAMPGO_LLM_API_BASE=
LAMPGO_LLM_PROVIDER=openai
LAMPGO_LLM_MODEL=gpt-4o-mini
LAMPGO_LLM_FAST_MODEL=gpt-4o-mini
LAMPGO_LLM_TIMEOUT_S=15
LAMPGO_LLM_WEB_SEARCH_ENABLED=true
LAMPGO_LLM_WEB_SEARCH_FORCE=false
LAMPGO_LLM_WEB_SEARCH_LIMIT=3
LAMPGO_LLM_WEB_SEARCH_MAX_KEYWORD=3
# 可选：给 MiMo 联网搜索一个近似位置，便于天气/本地信息查询
LAMPGO_LLM_WEB_SEARCH_COUNTRY=
LAMPGO_LLM_WEB_SEARCH_REGION=
LAMPGO_LLM_WEB_SEARCH_CITY=

# === 摄像头（LLM 视觉输入）===
# USB 摄像头，填设备索引（0 / 1）；留空 = 不附带图像
LAMPGO_CAMERA_PORT=

# === 手机控制（Open-AutoGLM）===
# 启用后会注册 phone_task 技能；Open-AutoGLM 已内置在 lampgo 中
# 模型地址、模型名和 key 统一使用上面的 LAMPGO_LLM_API_BASE / LAMPGO_LLM_MODEL / LAMPGO_LLM_API_KEY
LAMPGO_PHONE_ENABLED=false
LAMPGO_PHONE_PYTHON=
LAMPGO_PHONE_ADB=
LAMPGO_PHONE_DEVICE_TYPE=adb
LAMPGO_PHONE_DEVICE_ID=
LAMPGO_PHONE_WDA_URL=http://localhost:8100
LAMPGO_PHONE_LANG=cn
LAMPGO_PHONE_SKIP_MODEL_CHECK=true
LAMPGO_PHONE_VERIFY_RESULT=true
LAMPGO_PHONE_ARTIFACT_DIR=.lampgo/phone-artifacts
LAMPGO_PHONE_AUTO_INSTALL_ADB_KEYBOARD=true
LAMPGO_PHONE_MAX_STEPS=10
LAMPGO_PHONE_TIMEOUT_S=300

# === 语音配置 ===
# STT: omni (mimo-v2-omni, 推荐) 或 whisper
LAMPGO_VOICE_STT_PROVIDER=omni
LAMPGO_VOICE_STT_MODEL=mimo-v2-omni
# TTS: mimo (mimo-v2-tts, 推荐) 或 edge-tts (免费离线)
LAMPGO_VOICE_TTS_PROVIDER=mimo
LAMPGO_VOICE_TTS_VOICE=mimo_default
LAMPGO_VOICE_TTS_STYLE_PROMPT=
# 语音聊天用的 LLM 模型 (支持 stream)
LAMPGO_VOICE_CHAT_MODEL=mimo-v2-pro
LAMPGO_VOICE_MIC_DEVICE=

# === 录制目录 ===
LAMPGO_RECORDINGS_DIR=assets/recordings

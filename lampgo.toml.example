# lampgo 配置字段参考文档（schema reference — lampgo 不会读这个文件）
#
# 运行时读取的唯一 TOML 是 ~/.lampgo/config.toml，由 `lampgo onboard` 和
# Web UI 配置页自动写入/维护。本文件仅作为字段参考（可看字段名、默认值、注释）。
#
# 配置优先级（高 → 低）：
#   CLI 参数  >  环境变量 (LAMPGO_*, 可写在 ./.env 里)
#             >  ~/.lampgo/config.toml
#             >  内置默认值
#
# 首次安装/迁移旧配置：`uv run lampgo onboard`

[device]
motor_port = "/dev/ttyUSB0"    # Feetech 电机总线串口 (必填，你的设备可能不同)
lamp_id = "AL02"               # 设备标识，用于校准文件查找
use_degrees = true             # true = 角度模式, false = 归一化 -100~100

[motion]
tick_rate_hz = 50.0            # 控制循环频率 (Hz)
default_max_velocity = 120.0   # 默认最大速度 (度/秒)；仅作为弹簧频率的速度预算上限
idle_sway_enabled = true       # 空闲后是否自动触发出厂技能 idle_sway
idle_sway_idle_after_s = 600.0 # 空闲多久后开始触发（默认 10 分钟）
idle_sway_interval_s = 30.0    # 空闲后触发间隔基准
idle_sway_interval_jitter_s = 8.0 # 间隔随机浮动范围（±秒）
idle_sway_duration_s = 8.0     # 每次 idle_sway 持续时长
idle_sway_amplitude = 6.0      # 每次 idle_sway 摆动幅度（度）
idle_sway_period_s = 4.5       # 摆动周期（秒）
# 注：motion 不存在 default_max_acceleration —— 动力学是弹簧-阻尼，加速度是隐式的。
#     真正的硬加速度上限在下面的 [safety].max_acceleration。

[safety]
max_velocity = 180.0           # 安全速度硬上限 (度/秒)
max_acceleration = 900.0       # 安全加速度硬上限 (度/秒²)

[llm]
provider = "openai"            # LLM 提供商: openai, anthropic, gemini, local
model = "gpt-4o-mini"          # 复杂推理任务模型
fast_model = "gpt-4o-mini"     # 快速意图分类模型
enable_thinking = false        # 默认是否开启思考模式（聊天界面不再单独选择）
# api_key 不要写在这里！请用 .env 文件或环境变量 LAMPGO_LLM_API_KEY
api_base = ""                  # 自定义 API 地址 (本地/代理模型)
temperature = 0.3
# 单轮 LLM 回复 token 上限（OpenAI: max_tokens；MiMo: max_completion_tokens）
# 多轮工具调用建议 ≥ 2048；复杂长回复可到 8192
max_tokens = 4096
# 每日记忆 / 会话摘要任务专用预算。推理模型（mimo-v2-omni / o-系列 / deepseek-r1）
# 会把预算花在思考链上，至少给 4096 才能稳定产出 bullet
summary_max_tokens = 8192
# 模型输入上下文窗口；目前仅作信息记录，将来用于历史消息自动裁剪
# mimo-v2-pro/omni ≈ 128000、Claude Sonnet ≈ 200000、gpt-4o-mini ≈ 128000
context_window = 128000
timeout_s = 15.0
web_search_enabled = true      # MiMo 支持时启用内置联网搜索
web_search_force = false       # false = 模型自行判断是否联网
web_search_limit = 3
web_search_max_keyword = 3
# 可选：给 MiMo 联网搜索一个近似位置，便于天气/本地信息查询
web_search_country = ""
web_search_region = ""
web_search_city = ""

[camera]
port = ""                      # USB 摄像头索引（0 / 1）；留空 = 不附带图像给 LLM

[phone_agent]
enabled = false                # true = 注册 phone_task 技能，通过内置 Open-AutoGLM 控制手机
python_executable = ""         # 留空时使用当前 lampgo Python；高级用法可指定其它 Python
adb_path = ""                  # adb 可执行文件路径；留空时自动从 PATH / Android SDK 常见目录查找
device_type = "adb"            # adb / hdc / ios
device_id = ""                 # adb devices -l / hdc list targets / iOS UDID 中看到的设备 ID
wda_url = "http://localhost:8100"  # iOS WebDriverAgent URL，仅 device_type=ios 时使用
lang = "cn"                    # Open-AutoGLM 提示语言：cn / en
# 模型地址、模型名和 API key 统一使用 [llm].api_base / [llm].model / credentials 中的 llm_api_key
skip_model_check = true        # true = 跳过 Open-AutoGLM 每次任务前的模型 API 健康检查
verify_result = true           # true = 每次 phone_task 结束后截图并做轻量结果校验
artifact_dir = ".lampgo/phone-artifacts"  # 最终截图与 UIAutomator XML 保存目录
auto_install_adb_keyboard = true  # adb 模式下自动安装/启用随 lampgo 打包的 ADBKeyboard.apk
direct_control_enabled = true  # true = 简单任务先走 adb 直控（打开 App/返回/Home/点击文本/输入等），再回退 GUI agent
default_max_steps = 10
timeout_s = 300

[voice]
stt_provider = "volcengine"    # 语音转文字: volcengine
stt_model = "bigmodel"
tts_provider = "volcengine"    # 文字转语音: volcengine, edge-tts
tts_model = ""                 # 火山 TTS 可选模型；留空使用服务默认
tts_voice = "zh_female_vv_uranus_bigtts"
volcengine_app_id = ""         # 火山引擎 App ID；TTS 未配置时自动回退 edge-tts
volcengine_access_token = ""   # 火山引擎 Access Token
livekit_url = "https://rtc.yhaox.top" # 云端 LiveKit；SDK 内部会用云端鉴权取 token
livekit_tts_voice = "zh_female_vv_uranus_bigtts"
wake_word = ""                 # 唤醒词 (留空 = 禁用)
vad_enabled = false            # 语音活动检测
